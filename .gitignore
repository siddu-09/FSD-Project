# ──────────────────────────────────────────────
# Root .gitignore — BookNest
# ──────────────────────────────────────────────

# Dependencies
node_modules/

# Large data files (too big for GitHub — seed via script instead)
books_dataset.csv

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example
!client/.env.example
!server/.env.example

# Prisma local dev database
server/prisma/dev.db
server/prisma/*.db
*.sqlite
*.sqlite3

# Build outputs
client/dist/
client/dist-ssr/

# Logs
npm-debug.log*
yarn-debug.log*
logs/
*.log

# OS & editor artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.sw?
