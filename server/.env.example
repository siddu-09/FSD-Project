# For AWS RDS Postgres (recommended)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# For local Docker Postgres from server/docker-compose.yml
# DATABASE_URL=postgresql://admin:password@localhost:5432/bookstore?schema=public

JWT_SECRET=change_this_to_a_long_random_secret
PORT=5001

# Comma-separated list of frontend origins
# Example: https://main.d123abc.amplifyapp.com,https://booknest.yourdomain.com
CORS_ORIGIN=

# Optional Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
